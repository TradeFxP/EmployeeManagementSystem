@using UserRoles.ViewModels
@model ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="relative h-screen w-full flex items-center justify-center overflow-hidden font-sans selection:bg-blue-500/30">
    <!-- SWIRL BACKDROP -->
    <div class="absolute inset-0 z-0">
        <img src="~/images/ems_swirl_background.png" class="w-full h-full object-cover" alt="Background" />
        <div class="absolute inset-0 bg-blue-900/20 backdrop-blur-[1px]"></div>
    </div>

    <!-- MAIN CONTAINER -->
    <div class="relative z-10 w-full max-w-[440px] px-6 animate-fade-in-up">
        <!-- GLASS CARD -->
        <div class="bg-white/10 backdrop-blur-2xl border border-white/20 rounded-[2.5rem] p-10 md:p-12 shadow-2xl overflow-hidden">
            
            <!-- <div class="text-center mb-8">
                <span class="text-white text-xl font-bold tracking-tight">Your logo</span>
            </div> -->

            <div class="mb-8 text-center">
                <h1 class="text-3xl font-bold text-white mb-2">New Security Key</h1>
                <p class="text-white/60 text-sm">Update your access credentials</p>
            </div>

            <form asp-action="ChangePassword" method="post" novalidate class="space-y-6">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Token" />

                <div asp-validation-summary="ModelOnly" class="bg-red-500/20 border border-red-500/50 text-white p-3 rounded-xl text-xs mb-4 backdrop-blur-md"></div>

                <!-- EMAIL (ReadOnly) -->
                <div class="space-y-2 opacity-60">
                    <label asp-for="Email" class="block text-sm font-medium text-white/90 ml-1">Account Email</label>
                    <input asp-for="Email"
                           class="w-full bg-white/20 border-0 text-white rounded-xl px-4 py-3.5 cursor-not-allowed outline-none font-medium"
                           readonly />
                </div>

                <!-- NEW PASSWORD -->
                <div class="space-y-2">
                    <label asp-for="NewPassword" class="block text-sm font-medium text-white/90 ml-1">New Password</label>
                    <input asp-for="NewPassword"
                           type="password"
                           class="w-full bg-white border-0 text-slate-900 rounded-xl px-4 py-3.5 focus:outline-none focus:ring-2 focus:ring-blue-400 transition-all placeholder:text-slate-400"
                           placeholder="Min. 8 characters" />
                    <span asp-validation-for="NewPassword" class="text-[10px] text-red-300 font-bold block ml-1"></span>
                </div>

                <!-- CONFIRM PASSWORD -->
                <div class="space-y-2">
                    <label asp-for="ConfirmNewPassword" class="block text-sm font-medium text-white/90 ml-1">Confirm Password</label>
                    <input asp-for="ConfirmNewPassword"
                           type="password"
                           class="w-full bg-white border-0 text-slate-900 rounded-xl px-4 py-3.5 focus:outline-none focus:ring-2 focus:ring-blue-400 transition-all placeholder:text-slate-400"
                           placeholder="Re-enter password" />
                    <span asp-validation-for="ConfirmNewPassword" class="text-[10px] text-red-300 font-bold block ml-1"></span>
                </div>

                <div class="pt-4 flex flex-col gap-4">
                    <button type="submit" class="w-full bg-[#002b5c] hover:bg-[#001f44] text-white font-bold py-4 rounded-xl shadow-lg transition-all active:scale-[0.98]">
                        Update Password
                    </button>
                    
                    <a asp-action="Login" class="text-center text-sm font-semibold text-white/80 hover:text-white transition-all py-2">
                        Cancel
                    </a>
                </div>
            </form>

            <div class="mt-8 text-center border-t border-white/10 pt-6">
                <p class="text-xs text-white/50 uppercase tracking-[0.2em] font-bold">EMS Terminal v3.0</p>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes fade-in-up { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .animate-fade-in-up { animation: fade-in-up 0.6s ease-out forwards; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
