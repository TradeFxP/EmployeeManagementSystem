@model UserRoles.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="relative h-screen w-full flex items-center justify-center overflow-hidden font-sans selection:bg-blue-500/30">
    <!-- SWIRL BACKDROP -->
    <div class="absolute inset-0 z-0">
        <img src="~/images/ems_swirl_background.png" class="w-full h-full object-cover" alt="Background" />
        <div class="absolute inset-0 bg-blue-900/20 backdrop-blur-[1px]"></div>
    </div>

    <!-- MAIN LOGIN CONTAINER -->
    <div class="relative z-10 w-full max-w-[440px] px-6 animate-fade-in-up">
        <!-- GLASS CARD -->
        <div class="bg-white/10 backdrop-blur-2xl border border-white/20 rounded-[2.5rem] p-10 md:p-12 shadow-2xl overflow-hidden">
            
            <!-- Logo Placeholder -->
            <!-- <div class="text-center mb-8">
                <span class="text-white text-xl font-bold tracking-tight">Your logo</span>
            </div> -->

            <div class="mb-8">
                <h1 class="text-3xl font-bold text-white mb-2">Login</h1>
            </div>

            <form asp-action="Login" method="post" autocomplete="on" class="space-y-6">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="bg-red-500/20 border border-red-500/50 text-white p-3 rounded-xl text-xs mb-4 backdrop-blur-md"></div>

                <!-- EMAIL -->
                <div class="space-y-2">
                    <label asp-for="Email" class="block text-sm font-medium text-white/90 ml-1">Email</label>
                    <input asp-for="Email"
                           class="w-full bg-white border-0 text-slate-900 rounded-xl px-4 py-3.5 focus:outline-none focus:ring-2 focus:ring-blue-400 transition-all placeholder:text-slate-400"
                           placeholder="username@gmail.com"
                           autocomplete="username" />
                    <span asp-validation-for="Email" class="text-[10px] text-red-300 font-bold block ml-1"></span>
                </div>

                <!-- PASSWORD -->
                <div class="space-y-2">
                    <label asp-for="Password" class="block text-sm font-medium text-white/90 ml-1">Password</label>
                    <div class="relative">
                        <input asp-for="Password"
                               type="password"
                               class="w-full bg-white border-0 text-slate-900 rounded-xl px-4 py-3.5 focus:outline-none focus:ring-2 focus:ring-blue-400 transition-all placeholder:text-slate-400 pr-10"
                               placeholder="Password"
                               id="passwordInput"
                               autocomplete="current-password" />
                        <button type="button" 
                                onclick="togglePassword()"
                                class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition-all"
                                id="togglePasswordBtn">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-[10px] text-red-300 font-bold block ml-1"></span>
                </div>

                <div class="flex justify-start px-1">
                    <a asp-action="VerifyEmail" asp-controller="Account" class="text-xs font-semibold text-white/80 hover:text-white transition-all">Forgot Password?</a>
                </div>

                <div>
                    <button type="submit" class="w-full bg-[#002b5c] hover:bg-[#001f44] text-white font-bold py-4 rounded-xl shadow-lg transition-all active:scale-[0.98]">
                        Sign in
                    </button>
                </div>
            </form>

            <!-- Social Login -->
            <!-- <div class="mt-8 text-center">
                <p class="text-[10px] uppercase tracking-widest text-white/60 mb-6">or continue with</p>
                <div class="flex justify-center gap-4">
                    <div class="w-12 h-10 bg-white rounded-lg flex items-center justify-center cursor-pointer hover:bg-slate-50 transition-colors shadow-sm">
                        <i class="bi bi-google text-slate-900"></i>
                    </div>
                    <div class="w-12 h-10 bg-white rounded-lg flex items-center justify-center cursor-pointer hover:bg-slate-50 transition-colors shadow-sm">
                        <i class="bi bi-github text-slate-900"></i>
                    </div>
                    <div class="w-12 h-10 bg-white rounded-lg flex items-center justify-center cursor-pointer hover:bg-slate-50 transition-colors shadow-sm">
                        <i class="bi bi-facebook text-slate-900"></i>
                    </div>
                </div>
            </div> -->

            <!-- <div class="mt-10 text-center">
                <p class="text-xs text-white/70">
                    Don't have an account yet? <a href="#" class="font-bold text-white hover:underline transition-all">Register for free</a>
                </p>
            </div> -->
        </div>
    </div>
</div>

<style>
    @@keyframes fade-in-up { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .animate-fade-in-up { animation: fade-in-up 0.6s ease-out forwards; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePassword() {
            const input = document.getElementById("passwordInput");
            const btn = document.getElementById("togglePasswordBtn");
            const icon = btn.querySelector('i');

            if (input.type === "password") {
                input.type = "text";
                icon.className = "bi bi-eye-slash";
            } else {
                input.type = "password";
                icon.className = "bi bi-eye";
            }
        }
    </script>
}
