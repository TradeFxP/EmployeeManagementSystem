</style>

<script>
    (function () {
        // Load history tasks
        if (typeof loadArchivedTasks === 'function') {
            loadArchivedTasks('@Model.TeamName');
        }

        // Sync current team name
        window.currentTeamName = '@Model.TeamName';

        // Default Filter for Sub-Managers: show only their tasks by default
        const myId = window.currentUserId;
        const rolesMap = window.userRolesMap || {};
        const myRole = rolesMap[myId];

        if (myRole === "Sub Manager" || myRole === "Sub-Manager") {
            const assigneeFilter = document.getElementById('assigneeFilter');
            if (assigneeFilter) {
                assigneeFilter.value = myId;
                if (typeof filterBoardTasks === 'function') {
                    filterBoardTasks();
                }
            }
        }
    })();

    let _digiBackfillDone = false;

    function openViewDataModal() {
        // Always reset filters so fresh data is shown on open
        selectedCountries.clear();
        document.querySelectorAll('.task-data-row').forEach(r => r.style.display = '');
        const bulkContainer = document.getElementById('bulkAssignContainer');
        const filterBadge = document.getElementById('filteredCountBadge');
        const resetBtn = document.getElementById('resetFilterBtn');
        if (bulkContainer) bulkContainer.classList.add('d-none');
        if (filterBadge) filterBadge.classList.add('d-none');
        if (resetBtn) resetBtn.classList.add('d-none');

        // Auto-backfill Digi Leads custom fields on first open
        const teamName = '@Model.TeamName';
        if (teamName === 'Digi Leads' && !_digiBackfillDone) {
            _digiBackfillDone = true;
            fetch('/api/Tasks/BackfillDigiLeads', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(r => r.json())
            .then(data => {
                console.log('Backfill result:', data);
                if (data.success && data.message && !data.message.includes('0 of')) {
                    // Data was backfilled — reload to show it
                    location.reload();
                    return;
                }
                // No new data to backfill, just show modal
                showViewDataModalNow();
            })
            .catch(err => {
                console.error('Backfill error:', err);
                showViewDataModalNow();
            });
        } else {
            showViewDataModalNow();
        }
    }

    function showViewDataModalNow() {
        var myModal = new bootstrap.Modal(document.getElementById('viewDataModal'));
        myModal.show();
        // Default sort by Newest on open
        setTimeout(() => sortTableData('desc'), 200);
    }


    function resetViewDataFilter() {
        selectedCountries.clear();
        document.querySelectorAll('.task-data-row').forEach(r => r.style.display = '');
        const bulkContainer = document.getElementById('bulkAssignContainer');
        const filterBadge = document.getElementById('filteredCountBadge');
        const resetBtn = document.getElementById('resetFilterBtn');
        if (bulkContainer) bulkContainer.classList.add('d-none');
        if (filterBadge) filterBadge.classList.add('d-none');
        if (resetBtn) resetBtn.classList.add('d-none');
        // Re-sort to default
        sortTableData('desc');
    }

    function sortTableData(direction) {
        const body = document.getElementById('viewDataTableBody');
        const rows = Array.from(body.querySelectorAll('.task-data-row'));
        const headerUnassigned = document.getElementById('headerUnassigned');
        const headerAssigned = document.getElementById('headerAssigned');

        // Update button states
        document.querySelectorAll('.sort-btn').forEach(b => b.classList.remove('active', 'btn-primary'));
        if (direction === 'desc') document.getElementById('sortNewest').classList.add('active', 'btn-primary');
        else document.getElementById('sortOldest').classList.add('active', 'btn-primary');

        rows.sort((a, b) => {
            const timeA = parseInt(a.dataset.createdAt);
            const timeB = parseInt(b.dataset.createdAt);
            return direction === 'desc' ? timeB - timeA : timeA - timeB;
        });

        // Re-append in grouped order: Unassigned Header -> Unassigned Rows -> Assigned Header -> Assigned Rows
        if (headerUnassigned) body.appendChild(headerUnassigned);
        rows.filter(r => r.dataset.isUnassigned === 'true').forEach(row => body.appendChild(row));

        if (headerAssigned) body.appendChild(headerAssigned);
        rows.filter(r => r.dataset.isUnassigned === 'false').forEach(row => body.appendChild(row));
    }

    function showFieldDetail(cell) {
        const fullText = cell.getAttribute('data-full-text') || cell.innerText;
        const fieldName = cell.getAttribute('data-field-name') || 'Field Detail';
        
        document.getElementById('fieldDetailModalTitle').innerText = fieldName.toUpperCase();
        document.getElementById('fieldDetailModalContent').innerText = fullText;
        
        const modal = new bootstrap.Modal(document.getElementById('fieldDetailModal'));
        modal.show();
    }

    if (typeof window.selectedCountries === 'undefined') {
        window.selectedCountries = new Set();
    }
    var selectedCountries = window.selectedCountries;

    function prepareCountryFilter() {
        const countries = new Set();
        document.querySelectorAll('.country-cell').forEach(td => {
            const val = td.innerText.trim();
            if (val && val !== '-') countries.add(val);
        });

        const container = document.getElementById('countryListContainer');
        container.innerHTML = Array.from(countries).sort().map(c => `
            <div class="form-check py-1">
                <input class="form-check-input country-checkbox" type="checkbox" value="${c}" id="country_${c.replace(/\s/g, '_')}" ${selectedCountries.has(c) ? 'checked' : ''}>
                <label class="form-check-label small" for="country_${c.replace(/\s/g, '_')}">
                    ${c}
                </label>
            </div>
        `).join('');
    }

    function filterCountryList() {
        const query = document.getElementById('countrySearchInput').value.toLowerCase();
        document.querySelectorAll('#countryListContainer .form-check').forEach(div => {
            const text = div.innerText.toLowerCase();
            div.style.display = text.includes(query) ? '' : 'none';
        });
    }

    function applyCountryFilter() {
        selectedCountries.clear();
        document.querySelectorAll('.country-checkbox:checked').forEach(cb => {
            selectedCountries.add(cb.value);
        });

        const rows = document.querySelectorAll('.task-data-row');
        let visibleCount = 0;

        rows.forEach(row => {
            const countryCell = row.querySelector('.country-cell');
            const country = countryCell ? countryCell.innerText.trim() : '';

            if (selectedCountries.size === 0 || selectedCountries.has(country)) {
                row.style.display = '';
                visibleCount++;
            } else {
                row.style.display = 'none';
            }
        });

        const bulkContainer = document.getElementById('bulkAssignContainer');
        const filterBadge = document.getElementById('filteredCountBadge');
        const resetBtn = document.getElementById('resetFilterBtn');

        // Update group header visibility
        const unassignedVisible = Array.from(document.querySelectorAll('.task-data-row[data-is-unassigned="true"]')).some(r => r.style.display !== 'none');
        const assignedVisible = Array.from(document.querySelectorAll('.task-data-row[data-is-unassigned="false"]')).some(r => r.style.display !== 'none');
        
        const hUnassigned = document.getElementById('headerUnassigned');
        const hAssigned = document.getElementById('headerAssigned');
        
        if (hUnassigned) hUnassigned.style.display = unassignedVisible ? '' : 'none';
        if (hAssigned) hAssigned.style.display = assignedVisible ? '' : 'none';

        if (selectedCountries.size > 0) {
            bulkContainer.classList.remove('d-none');
            filterBadge.classList.remove('d-none');
            filterBadge.innerText = `Filtered: ${visibleCount}`;
            if (resetBtn) resetBtn.classList.remove('d-none');
        } else {
            bulkContainer.classList.add('d-none');
            filterBadge.classList.add('d-none');
            if (resetBtn) resetBtn.classList.add('d-none');
        }
    }

    function clearCountryFilter() {
        document.querySelectorAll('.country-checkbox').forEach(cb => cb.checked = false);
        selectedCountries.clear();
        applyCountryFilter();
    }

    function executeBulkAssign() {
        const userId = document.getElementById('bulkAssignUserSelect').value;
        if (!userId) {
            alert('Please select a user to assign to.');
            return;
        }

        const selectedRows = document.querySelectorAll('.task-checkbox:checked');
        const taskIds = Array.from(selectedRows).map(cb => parseInt(cb.closest('.task-data-row').dataset.taskId));

        if (taskIds.length === 0) {
            alert('Please select at least one task to assign.');
            return;
        }

        if (!confirm(`Assign ${taskIds.length} tasks to selected user?`)) return;

        fetch('/Tasks/BulkAssignTasks', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ taskIds: taskIds, userId: userId })
        })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    if (typeof showToast === 'function') {
                        showToast(`Successfully assigned ${data.count} tasks.`, 'success');
                    } else {
                        alert(`Successfully assigned ${data.count} tasks.`);
                    }
                    
                    // Update UI in the table
                    const userName = document.querySelector(`#bulkAssignUserSelect option[value="${userId}"]`).text;
                    selectedRows.forEach(cb => {
                        const row = cb.closest('.task-data-row');
                        const assigneeSpan = row.querySelector('.assignee-name');
                        if (assigneeSpan) assigneeSpan.innerText = userName;
                        const avatar = row.querySelector('.avatar-table-xs');
                        if (avatar) avatar.innerText = userName[0].toUpperCase();
                        cb.checked = false; // Uncheck after assign
                    });
                    document.getElementById('selectAllTasks').checked = false;
                } else {
                    alert('Failed to assign tasks.');
                }
            })
            .catch(err => {
                console.error(err);
                alert('An error occurred during bulk assignment.');
            });
    }

    function toggleSelectAll(mainCb) {
        document.querySelectorAll('.task-checkbox').forEach(cb => {
            const row = cb.closest('.task-data-row');
            if (row && row.style.display !== 'none') {
                cb.checked = mainCb.checked;
            }
        });
    }

    function quickAssignTask(taskId, userId, el) {
        let userName = el.innerText;
        if (userName.includes('] ')) userName = userName.split('] ')[1];
        
        fetch(`/Tasks/AssignTask?taskId=${taskId}&userId=${userId}`, {
            method: 'POST'
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                if (typeof showToast === 'function') {
                    showToast(`Assigned to ${userName}`, 'success');
                }
                const row = el.closest('.task-data-row');
                if (row) {
                    const assigneeSpan = row.querySelector('.assignee-name');
                    if (assigneeSpan) assigneeSpan.innerText = userName;
                    const avatar = row.querySelector('.avatar-table-xs');
                    if (avatar) avatar.innerText = userName[0].toUpperCase();
                }
            } else {
                if (typeof showToast === 'function') {
                    showToast(data.message || 'Error assigning task', 'error');
                } else {
                    alert(data.message || 'Error assigning task');
                }
            }
        })
        .catch(err => {
            console.error(err);
            if (typeof showToast === 'function') {
                showToast('Network error', 'error');
            }
        });
    }

</script>

<!-- 📊 VIEW DATA MODAL (EXCEL-LIKE) -->
<div class="modal fade" id="viewDataModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content border-0">
            <div class="modal-header bg-dark text-white shadow-sm">
                <h5 class="modal-title d-flex align-items-center">
                    <i class="bi bi-grid-3x3-gap-fill me-2 text-info"></i>
                    <span>@Model.TeamName - Data Overview</span>
                </h5>
                <div class="ms-auto d-flex gap-3 align-items-center me-3">
                    <div class="btn-group btn-group-sm shadow-sm rounded-pill overflow-hidden border">
                        <button class="btn btn-light sort-btn active" id="sortNewest" onclick="sortTableData('desc')">
                            <i class="bi bi-sort-numeric-down me-1"></i> Newest
                        </button>
                        <button class="btn btn-light sort-btn" id="sortOldest" onclick="sortTableData('asc')">
                            <i class="bi bi-sort-numeric-up me-1"></i> Oldest
                        </button>
                    </div>

                    <div id="bulkAssignContainer" class="d-none animate__animated animate__fadeIn">
                        <div class="input-group input-group-sm rounded-pill shadow-sm overflow-hidden"
                            style="border: 1px solid #0dcaf0;">
                            <span class="input-group-text bg-info text-white border-0"><i
                                    class="bi bi-person-plus-fill"></i></span>
                             <select id="bulkAssignUserSelect" class="form-select border-0"
                                style="width: 140px; font-size: 0.75rem;">
                                <option value="">Assign to...</option>
                                @if (Model.ManagementUsers != null && Model.ManagementUsers.Any())
                                {
                                    <optgroup label="MANAGEMENT">
                                        @foreach (var u in Model.ManagementUsers)
                                        {
                                            <option value="@u.Id">[@u.RoleName] @u.Name</option>
                                        }
                                    </optgroup>
                                }

                                @foreach (var group in Model.TeamGroups)
                                {
                                    <optgroup label="@group.TeamName.ToUpper()">
                                        @foreach (var u in group.Users)
                                        {
                                            <option value="@u.Id">
                                                @for (int i = 0; i < u.Level; i++)
                                                {
                                                    @Html.Raw("&nbsp;&nbsp;")
                                                }
                                                [@u.RoleName] @u.Name
                                            </option>
                                        }
                                    </optgroup>
                                }
                            </select>
                            <button class="btn btn-info text-white border-0" type="button"
                                onclick="executeBulkAssign()">
                                <i class="bi bi-check-lg"></i>
                            </button>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <span class="badge bg-secondary rounded-pill py-2 px-3 shadow-sm">Total: @Model.Columns.Sum(c =>
                            c.Tasks?.Count ?? 0)</span>
                        <span id="filteredCountBadge"
                            class="badge bg-info rounded-pill py-2 px-3 shadow-sm d-none">Filtered: 0</span>
                    </div>
                </div>
                <!-- Re-set button: clears filters, shows all data without closing modal -->
                <button id="resetFilterBtn" type="button" class="btn btn-sm btn-outline-warning me-2 d-none"
                    onclick="resetViewDataFilter()" title="Clear all filters and show all data">
                    <i class="bi bi-arrow-counterclockwise me-1"></i> Reset Filter
                </button>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                    aria-label="Close"></button>
            </div>
            <div class="modal-body p-0 bg-light">
                <div class="table-responsive h-100">
                    <table class="table table-hover table-bordered excel-style-table mb-0">
                        @{
                            // ─── Pre-compute: only show custom fields that have at least one non-empty value ───
                            var allTasks = Model.Columns.SelectMany(c => c.Tasks ?? new List<TaskItem>()).ToList();

                            // ─── Legacy Data Extraction Helper ───
                            // Description format from FormatLeadDescription:
                            //   **Name:** Azeem Chaudhary          (top-level properties)
                            //   - **Full Name:** Azeem Chaudhary   (questionnaire fields)
                            string ExtractFromDesc(string? desc, string fieldName) {
                                if (string.IsNullOrEmpty(desc)) return "-";
                                
                                // Build a mapping of field name aliases to try
                                var aliases = new List<string> { fieldName };
                                
                                // Add common aliases
                                var fn = fieldName.Trim().ToLower();
                                if (fn == "full name" || fn == "fullname") { aliases.Add("Full Name"); aliases.Add("Name"); }
                                if (fn == "phone") { aliases.Add("Phone"); }
                                if (fn == "email") { aliases.Add("Email"); }
                                if (fn == "company name") { aliases.Add("Company Name"); }
                                if (fn == "country") { aliases.Add("Country"); }
                                if (fn == "what best describes your business") { aliases.Add("What Best Describes Your Business"); }
                                if (fn == "what are you looking to launch") { aliases.Add("What Are You Looking To Launch"); }
                                
                                // Try each alias with the exact markdown format from FormatLeadDescription
                                foreach (var alias in aliases) {
                                    // Match pattern: **Alias:** Value  OR  - **Alias:** Value
                                    var pattern = $@"\*\*{System.Text.RegularExpressions.Regex.Escape(alias)}:\*\*\s*(.+)";
                                    var match = System.Text.RegularExpressions.Regex.Match(desc, pattern, System.Text.RegularExpressions.RegexOptions.IgnoreCase | System.Text.RegularExpressions.RegexOptions.Multiline);
                                    if (match.Success && !string.IsNullOrWhiteSpace(match.Groups[1].Value)) {
                                        return match.Groups[1].Value.Trim();
                                    }
                                }
                                
                                return "-";
                            }

                            // Fields logic: for "Digi Leads", we ensure requested headers are always visible
                            var requestedDigiFields = new[] { "Full Name", "Phone", "Email", "Company Name", "Country", "What Best Describes Your Business", "What Are You Looking To Launch" };
                            
                            // For Digi Leads, we want a SPECIFIC order independently of database ID
                            var activeFields = new List<UserRoles.Models.TaskCustomField>();

                            if (Model.TeamName == "Digi Leads") {
                                foreach(var reqName in requestedDigiFields) {
                                    var existing = Model.CustomFields.FirstOrDefault(f => f.FieldName?.Trim().ToLower() == reqName.Trim().ToLower());
                                    if (existing != null) {
                                        activeFields.Add(existing);
                                    } else {
                                        // Create a "ghost" field if it doesn't exist in DB yet
                                        activeFields.Add(new UserRoles.Models.TaskCustomField { 
                                            FieldName = reqName, 
                                            Id = -1, // Virtual ID
                                            TeamName = "Digi Leads",
                                            IsActive = true 
                                        });
                                    }
                                }
                            } else {
                                activeFields = Model.CustomFields
                                    .OrderBy(f => f.Order)
                                    .Where(f => allTasks.Any(t =>
                                            t.CustomFieldValues != null &&
                                            t.CustomFieldValues.Any(v => v.FieldId == f.Id && !string.IsNullOrWhiteSpace(v.Value))))
                                    .ToList();
                            }

                            // Standard field visibility
                            bool hasTitle       = allTasks.Any(t => !string.IsNullOrWhiteSpace(t.Title));
                            bool hasDesc        = allTasks.Any(t => !string.IsNullOrWhiteSpace(t.Description));
                            bool hasDueDate     = allTasks.Any(t => t.DueDate.HasValue);
                            bool hasAssigned    = allTasks.Any(t => t.AssignedToUser != null);
                            bool hasCreatedBy   = allTasks.Any(t => t.CreatedByUser != null);

                            int totalCols = 1 /* Selection */ + 1 /* ID */ + activeFields.Count
                                + (hasTitle ? 1 : 0) + (hasDesc ? 1 : 0) + 1 /* Priority */ + (hasDueDate ? 1 : 0)
                                + (hasAssigned ? 1 : 0) + (hasCreatedBy ? 1 : 0) + 1 /* Created At */ + 1 /* CURRENT STAGE */;
                        }
                        <thead class="sticky-top shadow-sm">
                            <tr class="header-row">
                                <th class="text-center" style="width: 40px;">
                                    <input type="checkbox" id="selectAllTasks" class="form-check-input" onclick="toggleSelectAll(this)">
                                </th>
                                <th class="text-center" style="width: 60px;">ID</th>
                                @if (hasAssigned) { <th style="min-width: 200px;">ASSIGNED TO</th> }

                                @* ── Custom fields first (in Excel column order) ── *@
                                @foreach (var field in activeFields)
                                {
                                    var isCountry = field.FieldName?.Trim().ToLower() == "country";
                                    <th class="custom-field-header" data-field-id="@field.Id">
                                        <div class="d-flex align-items-center justify-content-between gap-1">
                                            <span>@field.FieldName?.ToUpper()</span>
                                            @if (isCountry)
                                            {
                                                <div class="dropdown d-inline-block ms-1">
                                                    <button class="btn btn-link p-0 text-primary-emphasis" type="button"
                                                        data-bs-toggle="dropdown" aria-expanded="false"
                                                        onclick="event.stopPropagation(); prepareCountryFilter();">
                                                        <i class="bi bi-funnel"></i>
                                                    </button>
                                                    <div class="dropdown-menu shadow-lg border-0 p-3" style="min-width: 250px; border-radius: 12px;">
                                                        <div class="mb-3">
                                                            <h6 class="dropdown-header px-0 text-dark fw-bold mb-2">FILTER BY COUNTRY</h6>
                                                            <input type="text" class="form-control form-control-sm search-input"
                                                                id="countrySearchInput" placeholder="Search country..."
                                                                onkeyup="filterCountryList()">
                                                        </div>
                                                        <div id="countryListContainer" style="max-height: 200px; overflow-y: auto; scrollbar-width: thin;"></div>
                                                        <div class="d-flex gap-2 mt-3">
                                                            <button class="btn btn-sm btn-outline-secondary w-100 rounded-pill" onclick="clearCountryFilter()">Clear</button>
                                                            <button class="btn btn-sm btn-primary w-100 rounded-pill" onclick="applyCountryFilter()">Apply</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </th>
                                }

                                @* ── Standard fields after ── *@
                                @if (hasTitle) { <th>TITLE</th> }
                                @if (hasDesc)  { <th style="min-width: 200px;">DESCRIPTION</th> }
                                <th style="width: 150px;">CURRENT STAGE</th>
                                <th style="width: 120px;">PRIORITY</th>
                                @if (hasDueDate) { <th style="width: 140px;">DUE DATE</th> }
                                @if (hasCreatedBy) { <th>CREATED BY</th> }
                                <th style="width: 150px;">CREATED AT</th>
                            </tr>
</thead>
                        <tbody id="viewDataTableBody">
                            @if (allTasks.Any())
                            {
                                var unassignedAdminTasks = allTasks.Where(t => t.AssignedToUserId == null || (Model.UserRolesMap.GetValueOrDefault(t.AssignedToUserId, "User") == "Admin")).ToList();
                                var assignedTasks = allTasks.Except(unassignedAdminTasks).ToList();

                                if (unassignedAdminTasks.Any())
                                {
                                    <tr class="table-group-header" id="headerUnassigned" style="background: #eff6ff !important; border-bottom: 2px solid #dbeafe;">
                                        <td colspan="@totalCols" class="py-1 px-1 fw-bold text-uppercase text-blue-700" style="font-size: 0.8rem; letter-spacing: 0.05em; color: #1d4ed8;">
                                            <i class="bi bi-person-dash-fill me-2 fs-5 text-blue-500"></i> UNASSIGNED TASKS (ADMIN)
                                        </td>
                                    </tr>
                                    foreach (var task in unassignedAdminTasks)
                                    {
                                        var isUnassigned = true;
                                        var rowBgColor = "#eff6ff";
                                        var rowBorder = "border-left: 6px solid #3b82f6;";

                                        <tr class="task-data-row" 
                                            data-task-id="@task.Id" 
                                            data-created-at="@task.CreatedAt.Ticks" 
                                            data-is-unassigned="true"
                                            style="background-color: @rowBgColor !important; @rowBorder">
                                            
                                            <td class="text-center">
                                                <input type="checkbox" class="form-check-input task-checkbox">
                                            </td>
                                            <td class="text-center fw-bold text-muted">@task.Id</td>

                                            @if (hasAssigned)
                                            {
                                                <td class="small">
                                                    @{
                                                        var assigneeTeam = task.AssignedToUserId != null ? Model.UserTeamsMap.GetValueOrDefault(task.AssignedToUserId, "N/A") : "N/A";
                                                        var assigneeRole = task.AssignedToUserId != null ? Model.UserRolesMap.GetValueOrDefault(task.AssignedToUserId, "User") : "";
                                                        var assigneeName = task.AssignedToUser?.Name ?? "Unassigned";
                                                    }
                                                    <div class="d-flex align-items-center justify-content-between">
                                                        <div class="d-flex align-items-center">
                                                            <div class="avatar-table-xs me-2 bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center">
                                                                @(string.IsNullOrEmpty(assigneeName) ? "?" : assigneeName[0].ToString().ToUpper())
                                                            </div>
                                                            <div class="d-flex flex-column">
                                                                <span class="assignee-name fw-bold">@assigneeName</span>
                                                                <span class="text-muted" style="font-size: 0.65rem;">
                                                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-1 me-1">@assigneeTeam</span>
                                                                    <span class="text-info">@assigneeRole</span>
                                                                </span>
                                                            </div>
                                                        </div>
                                                        
                                                        <div class="dropdown ms-2">
                                                            <button class="btn btn-link p-0 text-muted" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Quick Assign">
                                                                <i class="bi bi-person-plus"></i>
                                                            </button>
                                                            <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="min-width: 200px; font-size: 0.8rem;">
                                                                <li class="dropdown-header">QUICK ASSIGN</li>
                                                                @if (Model.ManagementUsers != null && Model.ManagementUsers.Any())
                                                                {
                                                                    <li><hr class="dropdown-divider"></li>
                                                                    <li class="dropdown-header small text-primary">MANAGEMENT</li>
                                                                    @foreach (var u in Model.ManagementUsers)
                                                                    {
                                                                        <li><a class="dropdown-item" href="javascript:void(0)" onclick="quickAssignTask(@task.Id, '@u.Id', this)">[@u.RoleName] @u.Name</a></li>
                                                                    }
                                                                }
                                                                @foreach (var group in Model.TeamGroups)
                                                                {
                                                                    <li><hr class="dropdown-divider"></li>
                                                                    <li class="dropdown-header small text-info">@group.TeamName.ToUpper()</li>
                                                                    @foreach (var u in group.Users)
                                                                    {
                                                                        <li><a class="dropdown-item" href="javascript:void(0)" onclick="quickAssignTask(@task.Id, '@u.Id', this)">
                                                                            @for (int i = 0; i < u.Level; i++) { @Html.Raw("&nbsp;&nbsp;") }
                                                                            [@u.RoleName] @u.Name
                                                                        </a></li>
                                                                    }
                                                                }
                                                            </ul>
                                                        </div>
                                                    </div>
                                                </td>
                                            }

                                            @foreach (var field in activeFields)
                                            {
                                                var fv = task.CustomFieldValues?.FirstOrDefault(v => v.FieldId == field.Id);
                                                var isCountry = field.FieldName?.Trim().ToLower() == "country";
                                                <td class="small @(isCountry ? "country-cell" : "")" 
                                                    data-field-id="@field.Id" 
                                                    data-field-name="@field.FieldName"
                                                    data-full-text="@(fv?.Value ?? "-")"
                                                    onclick="showFieldDetail(this)"
                                                    style="cursor: pointer;">
                                                    @(fv?.Value ?? "-")
                                                </td>
                                            }

                                            @if (hasTitle) { <td class="fw-bold text-dark" data-field-name="Title" onclick="showFieldDetail(this)" style="cursor: pointer;">@task.Title</td> }
                                            @if (hasDesc)
                                            {
                                                <td class="text-muted small description-cell" 
                                                    title="Click to view full description" 
                                                    data-field-name="Description"
                                                    data-full-text="@task.Description"
                                                    onclick="showFieldDetail(this)"
                                                    style="cursor: pointer;">
                                                    @(string.IsNullOrEmpty(task.Description) ? "-" :
                                                      task.Description.Length > 80
                                                          ? task.Description.Substring(0, 80) + "…"
                                                          : task.Description)
                                                </td>
                                            }
                                            <td class="small fw-bold">
                                                <span class="badge rounded-pill bg-white text-black border border-blue-200 px-2 py-1 status-badge shadow-sm" data-status-task-id="@task.Id" style="color: #000 !important;">
                                                    @task.Status
                                                </span>
                                            </td>
                                            <td>
                                                @{
                                                    var pColor = task.Priority == UserRoles.Models.Enums.TaskPriority.Critical ? "danger" :
                                                                task.Priority == UserRoles.Models.Enums.TaskPriority.High    ? "warning" :
                                                                task.Priority == UserRoles.Models.Enums.TaskPriority.Medium  ? "info"    : "secondary";
                                                }
                                                <span class="badge bg-soft-@pColor text-@pColor border border-@pColor-subtle rounded-pill px-2">
                                                    <i class="bi bi-circle-fill me-1" style="font-size:0.4rem"></i>
                                                    @task.Priority.ToString()
                                                </span>
                                            </td>
                                            @if (hasDueDate)
                                            {
                                                <td class="text-muted small">@(task.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                            }
                                            @if (hasCreatedBy)
                                            {
                                                <td class="small text-muted">@task.CreatedByUser?.Name</td>
                                            }
                                            <td class="small text-muted">@task.CreatedAt.ToString("yyyy-MM-dd")</td>
                                        </tr>
                                    }
                                }

                                if (assignedTasks.Any())
                                {
                                    <tr class="table-group-header" id="headerAssigned" style="background: #f0fdf4 !important; border-bottom: 2px solid #dcfce7;">
                                        <td colspan="@totalCols" class="py-1 px-1 fw-bold text-uppercase text-green-700" style="font-size: 0.8rem; letter-spacing: 0.05em; color: #15803d;">
                                            <i class="bi bi-person-check-fill me-2 fs-5 text-success"></i> ASSIGNED TASKS
                                        </td>
                                    </tr>
                                    foreach (var task in assignedTasks)
                                    {
                                        var isUnassigned = false;
                                        var rowBgColor = "#f0fdf4";
                                        var rowBorder = "border-left: 6px solid #22c55e;";

                                        <tr class="task-data-row" 
                                            data-task-id="@task.Id" 
                                            data-created-at="@task.CreatedAt.Ticks" 
                                            data-is-unassigned="false"
                                            style="background-color: @rowBgColor !important; @rowBorder">
                                            
                                            <td class="text-center">
                                                <input type="checkbox" class="form-check-input task-checkbox">
                                            </td>
                                            <td class="text-center fw-bold text-muted">@task.Id</td>

                                            @if (hasAssigned)
                                            {
                                                <td class="small">
                                                    @{
                                                        var assigneeTeam = task.AssignedToUserId != null ? Model.UserTeamsMap.GetValueOrDefault(task.AssignedToUserId, "N/A") : "N/A";
                                                        var assigneeRole = task.AssignedToUserId != null ? Model.UserRolesMap.GetValueOrDefault(task.AssignedToUserId, "User") : "";
                                                        var assigneeName = task.AssignedToUser?.Name ?? "Unassigned";
                                                    }
                                                    <div class="d-flex align-items-center justify-content-between">
                                                        <div class="d-flex align-items-center">
                                                            <div class="avatar-table-xs me-2 bg-primary text-white rounded-circle d-flex align-items-center justify-content-center">
                                                                @(string.IsNullOrEmpty(assigneeName) ? "?" : assigneeName[0].ToString().ToUpper())
                                                            </div>
                                                            <div class="d-flex flex-column">
                                                                <span class="assignee-name fw-bold">@assigneeName</span>
                                                                <span class="text-muted" style="font-size: 0.65rem;">
                                                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-1 me-1">@assigneeTeam</span>
                                                                    <span class="text-info">@assigneeRole</span>
                                                                </span>
                                                            </div>
                                                        </div>

                                                        <div class="dropdown ms-2">
                                                            <button class="btn btn-link p-0 text-muted" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Quick Assign">
                                                                <i class="bi bi-person-plus"></i>
                                                            </button>
                                                            <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="min-width: 200px; font-size: 0.8rem;">
                                                                <li class="dropdown-header">QUICK ASSIGN</li>
                                                                @if (Model.ManagementUsers != null && Model.ManagementUsers.Any())
                                                                {
                                                                    <li><hr class="dropdown-divider"></li>
                                                                    <li class="dropdown-header small text-primary">MANAGEMENT</li>
                                                                    @foreach (var u in Model.ManagementUsers)
                                                                    {
                                                                        <li><a class="dropdown-item" href="javascript:void(0)" onclick="quickAssignTask(@task.Id, '@u.Id', this)">[@u.RoleName] @u.Name</a></li>
                                                                    }
                                                                }
                                                                @foreach (var group in Model.TeamGroups)
                                                                {
                                                                    <li><hr class="dropdown-divider"></li>
                                                                    <li class="dropdown-header small text-info">@group.TeamName.ToUpper()</li>
                                                                    @foreach (var u in group.Users)
                                                                    {
                                                                        <li><a class="dropdown-item" href="javascript:void(0)" onclick="quickAssignTask(@task.Id, '@u.Id', this)">
                                                                            @for (int i = 0; i < u.Level; i++) { @Html.Raw("&nbsp;&nbsp;") }
                                                                            [@u.RoleName] @u.Name
                                                                        </a></li>
                                                                    }
                                                                }
                                                            </ul>
                                                        </div>
                                                    </div>
                                                </td>
                                            }

                                            @foreach (var field in activeFields)
                                            {
                                                var fv = task.CustomFieldValues?.FirstOrDefault(v => v.FieldId == field.Id);
                                                string cellValue = fv?.Value ?? "-";
                                                
                                                if ((cellValue == "-" || string.IsNullOrEmpty(cellValue)) && Model.TeamName == "Digi Leads") {
                                                    cellValue = ExtractFromDesc(task.Description, field.FieldName ?? "");
                                                    
                                                    // Extra fallback for Full Name since it's usually stored in Title
                                                    if ((cellValue == "-" || string.IsNullOrEmpty(cellValue)) && (field.FieldName?.Trim().ToLower() == "full name" || field.FieldName?.Trim().ToLower() == "fullname")) {
                                                        cellValue = task.Title ?? "-";
                                                    }
                                                }

                                                var isCountry = field.FieldName?.Trim().ToLower() == "country";
                                                <td class="small @(isCountry ? "country-cell" : "")" 
                                                    data-field-id="@field.Id" 
                                                    data-field-name="@field.FieldName"
                                                    data-full-text="@cellValue"
                                                    onclick="showFieldDetail(this)"
                                                    style="cursor: pointer;">
                                                    @cellValue
                                                </td>
                                            }

                                            @if (hasTitle) { <td class="fw-bold text-dark" data-field-name="Title" onclick="showFieldDetail(this)" style="cursor: pointer;">@task.Title</td> }
                                            @if (hasDesc)
                                            {
                                                <td class="text-muted small description-cell" 
                                                    title="Click to view full description" 
                                                    data-field-name="Description"
                                                    data-full-text="@task.Description"
                                                    onclick="showFieldDetail(this)"
                                                    style="cursor: pointer;">
                                                    @(string.IsNullOrEmpty(task.Description) ? "-" :
                                                      task.Description.Length > 80
                                                          ? task.Description.Substring(0, 80) + "…"
                                                          : task.Description)
                                                </td>
                                            }
                                            <td class="small fw-bold">
                                                <span class="badge rounded-pill bg-white text-black border border-green-200 px-2 py-1 status-badge shadow-sm" data-status-task-id="@task.Id" style="color: #000 !important;">
                                                    @task.Status
                                                </span>
                                            </td>
                                            <td>
                                                @{
                                                    var pColor = task.Priority == UserRoles.Models.Enums.TaskPriority.Critical ? "danger" :
                                                                task.Priority == UserRoles.Models.Enums.TaskPriority.High    ? "warning" :
                                                                task.Priority == UserRoles.Models.Enums.TaskPriority.Medium  ? "info"    : "secondary";
                                                }
                                                <span class="badge bg-soft-@pColor text-@pColor border border-@pColor-subtle rounded-pill px-2">
                                                    <i class="bi bi-circle-fill me-1" style="font-size:0.4rem"></i>
                                                    @task.Priority.ToString()
                                                </span>
                                            </td>
                                            @if (hasDueDate)
                                            {
                                                <td class="text-muted small">@(task.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                            }
                                            @if (hasCreatedBy)
                                            {
                                                <td class="small text-muted">@task.CreatedByUser?.Name</td>
                                            }
                                            <td class="small text-muted">@task.CreatedAt.ToString("yyyy-MM-dd")</td>
                                        </tr>
                                    }
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="@totalCols" class="text-center py-5 text-muted border-0">
                                        <div class="pulse-container mb-3">
                                            <i class="bi bi-inbox fs-1 text-secondary opacity-50"></i>
                                        </div>
                                        <h6 class="fw-bold text-secondary">No data available for this board.</h6>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 📦 FIELD DETAIL MODAL -->
<div class="modal fade" id="fieldDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0" style="border-radius: 16px;">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold text-muted letter-spacing-1" id="fieldDetailModalTitle">FIELD DETAIL</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
                <div id="fieldDetailModalContent" class="text-dark fs-5 p-3 bg-light rounded-3" style="white-space: pre-wrap; word-wrap: break-word; min-height: 100px;">
                    <!-- Content will be injected here -->
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

