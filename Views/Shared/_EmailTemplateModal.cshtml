<!-- Email Template Selection Modal -->
<div class="modal fade shadow-lg" id="emailTemplateModal" tabindex="-1" aria-labelledby="emailTemplateModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content rounded-4 border-0">
            <div class="modal-header border-bottom px-4 pb-3" style="background-color: #f8f9fa;">
                <h5 class="modal-title fw-semibold text-primary d-flex align-items-center gap-2" id="emailTemplateModalLabel">
                    <i class="bi bi-envelope-check"></i> Send Mail
                </h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body px-4 py-4" style="background-color: #fbfcff;">
                <form id="emailTemplateForm" method="post" autocomplete="off">
                    <input type="hidden" id="emailTemplateTaskId" name="taskId" />

                    <!-- Step 1: Selection & Preview -->
                    <div id="emailStep1">
                        <!-- Template Selection Row -->
                        <div class="row mb-4">
                            <div class="col-md-12">
                                <label for="templateSelect" class="form-label fw-semibold text-secondary small text-uppercase tracking-wide">Select Template</label>
                                <select class="form-select border-2 shadow-sm rounded-3" id="templateSelect" required>
                                    <option value="" disabled selected>-- Choose a Template --</option>
                                    <!-- Populate dynamically -->
                                </select>
                            </div>
                        </div>

                        <!-- Email Preview Section -->
                        <div class="row">
                            <div class="col-md-12">
                                <label class="form-label fw-semibold text-secondary small text-uppercase tracking-wide">Preview</label>
                                <div class="border rounded-3 p-3 bg-white shadow-sm" style="min-height: 250px; max-height: 400px; overflow-y: auto;">
                                    <div id="emailPreviewContainer" class="d-none w-100">
                                        <iframe id="emailPreviewFrame" style="width: 100%; height: 350px; border: none;"></iframe>
                                    </div>
                                    <div id="emailPreviewLoading" class="text-center text-muted mt-5 d-none">
                                        <div class="spinner-border text-primary" role="status">
                                            <span class="visually-hidden">Loading...</span>
                                        </div>
                                        <p class="mt-2 text-primary">Generating Preview...</p>
                                    </div>
                                    <div id="emailPreviewEmpty" class="text-center text-muted mt-5">
                                        <i class="bi bi-envelope-paper display-4 text-light"></i>
                                        <p class="mt-2">Select a template to view the content.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Step 2: Confirmation -->
                    <div id="emailStep2" class="d-none">
                        <div class="alert alert-info border-0 shadow-sm rounded-3 mb-4">
                            <i class="bi bi-info-circle-fill me-2"></i> You are about to send the email shown in the preview. Please confirm the details below.
                        </div>

                        <!-- NEW: Explicit Paste Instruction -->
                        <div class="alert alert-warning border-0 shadow-sm rounded-3 mb-4 d-flex align-items-center gap-3">
                            <i class="bi bi-clipboard-check-fill fs-4 text-warning"></i>
                            <div>
                                <strong class="d-block">Rich Template Support</strong>
                                <span class="small">The full template will be <strong>automatically copied</strong>. Just press <strong>Ctrl+V (Paste)</strong> once Outlook opens to see the original design.</span>
                            </div>
                        </div>

                        <div class="bg-white border rounded-3 p-4 shadow-sm">
                            <div class="row mb-3 border-bottom pb-3">
                                <div class="col-3 text-muted fw-semibold small text-uppercase tracking-wide">From</div>
                                <div class="col-9 fw-bold text-dark" id="confirmFromEmail">--</div>
                            </div>
                            <div class="row mb-3 border-bottom pb-3">
                                <div class="col-3 text-muted fw-semibold small text-uppercase tracking-wide">To</div>
                                <div class="col-9 fw-bold text-primary" id="confirmToEmail">--</div>
                            </div>
                            <div class="row">
                                <div class="col-3 text-muted fw-semibold small text-uppercase tracking-wide">Template</div>
                                <div class="col-9 fw-bold text-dark" id="confirmTemplateName">--</div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Footer Step 1 -->
            <div class="modal-footer border-top bg-light px-4 py-3" id="footerStep1">
                <button type="button" class="btn btn-outline-secondary rounded-pill fw-semibold px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary rounded-pill fw-semibold px-4 d-flex align-items-center gap-2 shadow-sm" id="btnNextStep" disabled>
                    <span>Next</span>
                    <i class="bi bi-arrow-right"></i> 
                </button>
            </div>

            <!-- Footer Step 2 -->
            <div class="modal-footer border-top bg-light px-4 py-3 d-none" id="footerStep2">
                <button type="button" class="btn btn-outline-secondary rounded-pill fw-semibold px-4" id="btnBackStep">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </button>
                <button type="button" class="btn btn-primary rounded-pill fw-semibold px-4 d-flex align-items-center gap-2 shadow-sm" id="btnConfirmSendEmail">
                    <i class="bi bi-content-paste" id="sendEmailIcon"></i> 
                    <span id="sendEmailText">Copy & Open Outlook</span>
                </button>
            </div>
        </div>
    </div>
</div>
